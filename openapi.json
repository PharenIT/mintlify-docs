          },
          {
            "name": "team_id",
            "in": "query",
            "description": "Team UUID for team-scoped keys.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for paginated results.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Documents returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedDocuments"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        },
        "x-mint": {
          "href": "/api-reference/docs/list-documents",
          "metadata": {
            "title": "List documents",
            "sidebarTitle": "List documents",
            "description": "Read Pharen Docs documents, collections, versions, files, and access metadata."
          }
        }
      }
    },
    "/api/flow/workflows/": {
      "get": {
        "tags": ["Workflows"],
        "summary": "List workflows",
        "description": "Fetch workflow definitions available to the API key. Requires the `workflows:read` scope.",
        "operationId": "listWorkflows",
        "parameters": [
          {
            "name": "team_id",
            "in": "query",
            "description": "Team UUID for team-scoped keys.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for paginated results.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Workflows returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedWorkflows"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        },
        "x-mint": {
          "href": "/api-reference/workflows/list-workflows",
          "metadata": {
            "title": "List workflows",
            "sidebarTitle": "List workflows",
            "description": "Read workflow definitions, versions, validation results, and execution plans."
          }
        }
      }
    },
    "/api/flow/workflows/{workflow_uuid}/execute/": {
      "post": {
        "tags": ["Workflows"],
        "summary": "Run workflow",
        "description": "Execute a workflow with optional JSON input. Requires the `workflows:run` scope.",
        "operationId": "runWorkflow",
        "parameters": [
          {
            "name": "workflow_uuid",
            "in": "path",
            "required": true,
            "description": "Workflow UUID.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunWorkflowRequest"
              },
              "examples": {
                "input": {
                  "summary": "Workflow input",
                  "value": {
                    "input": {
                      "source": "api",
                      "customer_id": "cus_123"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow execution started or completed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowRun"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "x-mint": {
          "href": "/api-reference/workflows/run-workflow",
          "metadata": {
            "title": "Run workflow",
            "sidebarTitle": "Run workflow",
            "description": "Execute a Pharen workflow from an internal tool, cron job, or external automation."
          }
        }
      }
    },
    "/api/agents/": {
      "get": {
        "tags": ["Agents"],
        "summary": "List agents",
        "description": "Fetch agents available to the API key. Requires the `agents:read` scope.",
        "operationId": "listAgents",
        "parameters": [
          {
            "name": "team_id",
            "in": "query",
            "description": "Team UUID for team-scoped keys.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for paginated results.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agents returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedAgents"
