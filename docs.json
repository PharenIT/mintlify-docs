{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Pharen",
  "description": "Documentation for Pharen Hub — the AI workspace that unifies docs, lists, channels, mail, and agents so your team can automate workflows and move faster.",
  "colors": {
    "primary": "#158065",
    "light": "#158065",
    "dark": "#6ee7b7"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "api": {
    "mdx": {
      "server": "https://pharen.app",
      "auth": {
        "method": "bearer"
      }
    },
    "playground": {
      "display": "interactive",
      "proxy": true,
      "url": "full"
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required",
      "prefill": true
    }
  },
  "logo": {
    "light": "https://media.brand.dev/70fa3769-6705-48e9-8340-cef95a902e88.svg",
    "dark": "https://media.brand.dev/de991512-f9de-434e-866d-6c978fec7b16.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Hub",
      "href": "https://pharen.app"
    }
  },
